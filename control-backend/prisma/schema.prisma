generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CategoryType {
  INCOME
  EXPENSE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  currency  String   @default("PEN")
  createdAt DateTime @default(now())

  categories   Category[]
  transactions Transaction[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      CategoryType
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  description String?
  date        DateTime
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
}